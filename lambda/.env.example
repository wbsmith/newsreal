# ─── Local LLM server (LM Studio / Ollama / vLLM, OpenAI-compatible) ───
# LM Studio default:
LLM_BASE_URL=http://localhost:1234/v1
# Ollama default would be: http://localhost:11434/v1

# Model IDs as they appear in the server (LM Studio: copy from the "API Identifier" column)
LOCAL_CLASSIFY_MODEL=nvidia/nemotron-3-nano-omni
LOCAL_ANALYZE_MODEL=google/gemma-4-31b

# Most local servers don't need an API key; placeholder is fine
LLM_API_KEY=not-needed

# ─── Pipeline tuning ───
# LM Studio serializes requests through one loaded model, so batch_size > 1
# doesn't speed things up unless your server supports continuous batching.
# Start small to get fast feedback, then ramp up.
CLASSIFY_COUNT=30
CLASSIFY_BATCH_SIZE=1
DEEP_ANALYZE_COUNT=10
ANALYZE_BATCH_SIZE=1

# Reasoning models (e.g. Nemotron Nano) burn tokens thinking before emitting
# JSON. If you see "Failed to parse classification" errors with truncated JSON,
# bump these higher. Non-reasoning models can use much lower values (1024-2048).
CLASSIFY_MAX_TOKENS=4096
ANALYZE_MAX_TOKENS=8192

# ─── AWS (writes to the same DynamoDB tables the deployed site reads) ───
# Region only — credentials come from ~/.aws/credentials via default chain.
# If you want to override, also set NEWSREAL_AWS_ACCESS_KEY_ID and NEWSREAL_AWS_SECRET_ACCESS_KEY.
NEWSREAL_AWS_REGION=us-east-1
